<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome adaptive-icon foreground for Android 13+ themed icons.
  Bitmap wrapper that points at the per-density mipmap silhouette PNGs
  (shield+box mass in solid black on transparent). The platform tints
  this to match the user's wallpaper.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@mipmap/ic_launcher_monochrome"
    android:gravity="fill" />
