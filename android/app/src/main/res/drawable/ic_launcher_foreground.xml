<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground for Tangible — bitmap wrapper that points at
  the per-density mipmap PNGs generated from web/static/branding/logo-mark.png.
  The 432x432 (xxxhdpi) PNG places the mark inside the 72dp safe zone of the
  108dp adaptive-icon canvas, so any launcher mask (circle/squircle/square)
  shows the full shield without clipping.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@mipmap/ic_launcher_foreground"
    android:gravity="fill" />
